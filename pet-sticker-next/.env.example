# remove.bg 배경 제거 API 키
REMOVE_BG_API_KEY=your_remove_bg_api_key_here

# ML 품질 예측 서비스(pet-sticker-ml) 주소
# 로컬 직접 실행: http://localhost:8000 / docker compose: http://ml:8000
ML_SERVICE_URL=http://localhost:8000
# ML 호출 타임아웃(ms)
ML_TIMEOUT_MS=3000

# 관리자 페이지(/admin) 보호
ADMIN_PASSWORD=admin1234
ADMIN_SECRET=change-me-in-production
