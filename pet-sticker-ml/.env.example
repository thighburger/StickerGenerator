# 스티커 품질 ML 추론 서비스 환경변수
# 서빙 모드: champion(포터블 export 사용) | registry(MLflow 레지스트리 직접)
MODEL_MODE=champion

# 경로 오버라이드 (Docker/배포 시)
# CHAMPION_DIR=/app/champion
# LOG_DIR=/app/logs
# PET_STICKER_DATA_DIR=/app/data

# MLflow tracking (기본: 로컬 파일스토어 file:./mlruns)
# MLFLOW_TRACKING_URI=http://localhost:5000
# MLFLOW_EXPERIMENT_NAME=pet-sticker-quality
